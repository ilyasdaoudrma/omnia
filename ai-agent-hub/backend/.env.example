# ───────────────────────────── Backend env ─────────────────────────────
# Copy to `.env`. The server runs in AI_PROVIDER=mock with no keys, but you
# still need a reachable DATABASE_URL for persistence.

# HTTP
PORT=3000
# Comma-separated allowed CORS origins (the frontend dev server + prod URL).
CORS_ORIGINS=http://localhost:5180

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_agent_hub?schema=public

# AI provider: mock | claude | openai | groq
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Groq — free, OpenAI-compatible Llama inference (https://console.groq.com).
# Single key OR a comma-separated pool for automatic failover/rotation.
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# Clerk (server-side token verification). Leave blank to allow anonymous/guest.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# OMNIA marketplaces the agent searches (separate apps, shared Clerk identity).
STAYS_API_URL=http://localhost:3001
EATS_API_URL=http://localhost:3002
RIDES_API_URL=http://localhost:3003

# Shared secret for the trusted server-to-server path: the recurring-task
# scheduler places orders/bookings/rides on a user's behalf. MUST be identical
# in all 4 backends' .env. Generate a long random value; keep it server-only.
OMNIA_AGENT_SECRET=

# Optional: restrict POST /recurrences/admin/run-due to these IPs (comma list).
# Leave blank in dev; set to your internal/ops IPs in production.
RECURRENCE_ADMIN_IPS=

# Optional: gate GET /health/keys (Groq key-pool status) behind an admin token.
HEALTH_ADMIN_TOKEN=

# production locks down /health/keys when no HEALTH_ADMIN_TOKEN is set.
NODE_ENV=development

# Agent request caps per user (or IP when signed out), powering the usage meter.
# /agent/run is limited to AGENT_RATE_PER_MIN per minute (throttler) and
# AGENT_RATE_PER_DAY per day (UsageService). Defaults: 20/min, 300/day.
AGENT_RATE_PER_MIN=20
AGENT_RATE_PER_DAY=300

# Set to 1 to DISABLE all rate limiting (e.g. a heavy test pass). 0 = enforced.
DISABLE_RATE_LIMIT=0
