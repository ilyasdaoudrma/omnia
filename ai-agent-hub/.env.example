# ─────────────────────────────────────────────────────────────
#  AI Agent Hub — environment configuration
#  Copy this file to `.env` and fill in your keys.
#  Anything exposed to the browser MUST be prefixed with VITE_.
# ─────────────────────────────────────────────────────────────

# Clerk Authentication (https://dashboard.clerk.com → API Keys)
# The publishable key is safe to ship to the browser.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# AI provider selection: "claude" | "openai" | "mock"
# Default is "mock" so the app runs with zero keys.
VITE_AI_PROVIDER=mock

# Backend API base URL. The browser talks to YOUR backend, which
# holds the secret AI keys — never put OpenAI/Anthropic secret keys
# in a VITE_ variable, they would be exposed to every visitor.
VITE_API_BASE_URL=http://localhost:3000

# ── Server-side only (consumed by the NestJS backend, not the browser) ──
# These live here as documentation for the backend phase. They are NOT
# read by the frontend.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_agent_hub
