# OMNIA Eats backend
PORT=3002
CORS_ORIGINS=http://localhost:5182,http://localhost:5180
DATABASE_URL=postgresql://user:pass@host/omnia_eats?sslmode=require
# Use the SAME Clerk keys across all OMNIA apps for shared identity.
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# Shared secret that lets the OMNIA agent scheduler place recurring orders
# server-to-server (no user session). MUST match the value in all 4 backends.
OMNIA_AGENT_SECRET=
