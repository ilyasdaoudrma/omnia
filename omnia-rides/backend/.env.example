# OMNIA Rides backend
PORT=3003
CORS_ORIGINS=http://localhost:5183,http://localhost:5180
DATABASE_URL=postgresql://user:pass@host/omnia_rides?sslmode=require
# Public origin this backend is reachable at. Car images (served from public/cars)
# are rewritten to this origin at response time so they load on the deployed host.
# Defaults to http://localhost:3003 in dev. In production set the real URL, e.g.
# PUBLIC_BASE_URL=https://ilyashunter55-omnia-rides-api.hf.space
PUBLIC_BASE_URL=
# Use the SAME Clerk keys across all OMNIA apps for shared identity.
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# Shared secret that lets the OMNIA agent scheduler place recurring rides
# server-to-server (no user session). MUST match the value in all 4 backends.
OMNIA_AGENT_SECRET=
